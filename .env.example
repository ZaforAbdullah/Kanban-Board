# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=kanban
POSTGRES_PASSWORD=kanbanpass
POSTGRES_DB=kanban

# ── Server ─────────────────────────────────────────────────────────────────
# Full Prisma connection string (used by the backend service)
DATABASE_URL=postgresql://kanban:kanbanpass@db:5432/kanban

# For local development (outside Docker):
# DATABASE_URL=postgresql://kanban:kanbanpass@localhost:5432/kanban

JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Allowed CORS origin (must match where your frontend is hosted)
CORS_ORIGIN=http://localhost:3000

# ── Client ─────────────────────────────────────────────────────────────────
# GraphQL endpoint visible to the browser.
# In Docker Compose: keep localhost:4000 so the browser can reach it.
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
